# Test runner image — runs integration tests against the live app container
FROM node:22-alpine AS test-runner

WORKDIR /app

# Copy package files first to leverage layer caching
COPY package*.json ./

# Install all deps (including devDependencies for test runner)
RUN npm ci

# Copy source (test files only need app/integration/)
COPY . .

# Run API integration tests against the app container
# STAGING_URL is injected by docker-compose at runtime
CMD ["npm", "run", "test:integration:api"]